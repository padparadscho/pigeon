#, javascript-format
msgid "Unable to check emails: %s"
msgstr "Verificacion impossibla dels corrièls : %s"

#: src/manager.js
msgid "Error loading email accounts"
msgstr "Error de cargament dels de corrièr"

#: src/prefs.js
msgid "Notifications"
msgstr "Notificacions"

#: src/prefs.js
msgid "Configure notification behavior"
msgstr "Configurar lo compòrtament de las notificacions"

#: src/prefs.js
msgid "Priority only"
msgstr "Prioritaris solament"

#: src/prefs.js
msgid "Only notify for important emails"
msgstr "Avertir unicament pels corrièls importants"

#: src/prefs.js
msgid "Check interval"
msgstr "Relambi de verificacion"

#: src/prefs.js
