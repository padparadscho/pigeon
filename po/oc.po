msgid "Play a notification sound when new emails arrive"
msgstr "Emetre un son de notificacion quand de corrièls novèls arriban"

#: src/prefs.js
msgid "Persistent notifications"
msgstr "Notificacions persistentas"

#: src/prefs.js
msgid "Keep notifications visible until dismissed"
msgstr "Daissar las notificacions visiblas dusca las ignorar"

#: src/prefs.js
msgid "Email Client"
msgstr "Client de messatjariá"

#: src/prefs.js
msgid "Configure how to open emails"
msgstr "Configurar cossí dobrir los corrièls"

#: src/prefs.js
msgid "Use default email client"
msgstr "Utilizar lo client de corrièl per defaut"

#: src/prefs.js
msgid "Launch mail client when clicking notifications"
msgstr "Lançar lo client de corrièl en clicant las notificacions"
